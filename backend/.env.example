# MongoDB Connection String
# Para producción: obtener de MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<password>@cluster.xxxxx.mongodb.net/<nombre-db>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/dreamsdb

# JWT Secret Key (cambiar por un valor seguro en producción)
JWT_SECRET=mi_secreto_super_seguro

# Puerto del servidor (Render asigna automáticamente en producción)
PORT=4000
